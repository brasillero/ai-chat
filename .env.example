# Copy this file to .env.local and fill in the values:
#   cp .env.example .env.local
# (.env.local is gitignored; this template is safe to commit.)

# --- Default provider: OpenAI ---
# Get a key at https://platform.openai.com/api-keys
# Required unless LOCAL_LM_PROVIDER is set below.
# The model defaults to gpt-5.1 (see DEFAULT_OPENAI_MODEL in app/api/chat/route.ts).
OPENAI_API_KEY=

# --- Optional: local OpenAI-compatible provider ---
# Works with LM Studio, llama.cpp, Ollama, or any OpenAI-compatible endpoint.
# When LOCAL_LM_PROVIDER is set, it takes precedence over OpenAI and
# LOCAL_LM_IDENTIFIER becomes required — use the exact model id the server exposes.
# LOCAL_LM_PROVIDER=http://localhost:1234/v1
# LOCAL_LM_IDENTIFIER=qwen2.5-7b-instruct
